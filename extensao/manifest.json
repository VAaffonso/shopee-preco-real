{
    "manifest_version": 3,
    "name": "Shopee Preço Real",
    "version": "1.0",
    "description": "Mostra o histórico de preço de produtos da Shopee",
    "permissions": ["storage", "notifications"],
    "host_permissions": [
        "*://*.shopee.com.br/*",
        "https://shopee-preco-real.onrender.com/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "Shopee Preço Real"
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": ["*://*.shopee.com.br/*"],
            "js": ["content.js"],
            "css": ["style.css"]
        }
    ]
}